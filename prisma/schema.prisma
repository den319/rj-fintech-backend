// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions = [ltree]
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model UserMaster {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  email      String   @unique
  password   String
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt DateTime?

  companies UserMapping[]
  managedMappings  UserMapping[] @relation("ManagerToSubordinate")

  @@index([email])
  @@index([id])

}

model CompanyMaster {
  id         String   @id @default(uuid()) @db.Uuid
  gst        String?  @unique
  legalName  String
  address    String
  registeredAt DateTime
  brand      String?
  companyCode String @unique
  ieCode String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt DateTime?

  users UserMapping[]

  orgStructure OrgStructure[]

}

model GroupCompanyMaster {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  code       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt DateTime?


}

model UserActivity {
  id         String   @id @default(uuid()) @db.Uuid
  token      String
  version    String
  userId     String   @unique @db.Uuid
  userAgent  String
  ip         String
  tabId      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  expireAt   DateTime

  @@index([userId])
}

model UserMapping {
  userId     String @db.Uuid
  companyId  String @db.Uuid

  reportingManagerId String @db.Uuid
  status             UserStatus @default(ACTIVE)
  designation        String?  
  employeeId         String?    @unique

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    UserMaster    @relation(fields: [userId], references: [id])
  company CompanyMaster @relation(fields: [companyId], references: [id])
  reportingManager   UserMaster   @relation("ManagerToSubordinate", fields: [reportingManagerId], references: [id])

  @@id([userId, companyId])
  @@index([companyId])
}

model CompanyMapping {
  companyId        String @db.Uuid
  groupCompanyId   String @db.Uuid
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@id([companyId, groupCompanyId]) // composite primary key
  @@index([groupCompanyId])
}

model OrgStructure {
  id        String   @id @default(uuid()) @db.Uuid
  nodeName  String  
  nodeType  String   
  
  // Ltree configuration
  nodePath  Unsupported("ltree") 
  
  // Relations
  companyId String    @db.Uuid
  company   CompanyMaster @relation(fields: [companyId], references: [id])

  parentId  String?   @db.Uuid
  parent    OrgStructure?  @relation("ParentChild", fields: [parentId], references: [id])
  children  OrgStructure[] @relation("ParentChild")

  // GiST index is essential for ltree performance
  @@index([nodePath], map: "node_path_gist_idx", type: Gist)
}