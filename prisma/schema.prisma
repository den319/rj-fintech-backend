// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions = [ltree]
}

model UserMaster {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt DateTime?

  // Relations
  // activities   UserActivity[]
  // companies    UserMapping[]

  @@index([email])
  @@index([id])

}

model CompanyMaster {
  id         String   @id @default(uuid()) @db.Uuid
  gst        String?  @unique
  legalName  String
  address    String
  registeredAt DateTime
  brand      String?
  companyCode String @unique
  ieCode String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt DateTime?

  orgStructure OrgStructure[]

  // Relations
  // users        UserMapping[]
  // groupLinks   CompanyMapping[]

}

model GroupCompanyMaster {
  id         String   @id @default(uuid())
  name       String
  code       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt DateTime?

  // Relations
  // companies   CompanyMapping[]

}

model UserActivity {
  id         String   @id @default(uuid())
  token      String
  version    String
  userId     String   @unique
  userAgent  String
  ip         String
  tabId      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  expireAt   DateTime

  // Relation
  // user       UserMaster @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserMapping {
  userId     String
  companyId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  // user     UserMaster    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // company  CompanyMaster @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@index([companyId])
}

model CompanyMapping {
  companyId        String
  groupCompanyId   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  // company       CompanyMaster       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // groupCompany  GroupCompanyMaster @relation(fields: [groupCompanyId], references: [id], onDelete: Cascade)

  @@id([companyId, groupCompanyId]) // composite primary key
  @@index([groupCompanyId])
}

model OrgStructure {
  id        String   @id @default(uuid()) @db.Uuid
  nodeName  String  
  nodeType  String   
  
  // Ltree configuration
  nodePath  Unsupported("ltree") 
  
  // Relations
  companyId String    @db.Uuid
  company   CompanyMaster @relation(fields: [companyId], references: [id])

  parentId  String?   @db.Uuid
  parent    OrgStructure?  @relation("ParentChild", fields: [parentId], references: [id])
  children  OrgStructure[] @relation("ParentChild")

  // GiST index is essential for ltree performance
  @@index([nodePath], map: "node_path_gist_idx", type: Gist)
}