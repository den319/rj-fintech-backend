// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions = [ltree]
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum Category {
  SYSTEM_ACCESS
}

enum SubCategory {
  ADMIN
  USER_ACC
  ORG_STR
  WORK_FLOW
}

enum PermissionLevel {
  VIEWER
  USER
  MANAGER
}

enum AccessType {
  PRIMARY
  SECONDARY
}

model UserMaster {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  email      String   @unique
  password   String
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt DateTime?

  companies UserMapping[]
  managedMappings  UserMapping[] @relation("ManagerToSubordinate")

  accessLogs     UserAccess[]

  @@index([email])
  @@index([id])

}

model CompanyMaster {
  id         String   @id @default(uuid()) @db.Uuid
  gst        String?  @unique
  legalName  String
  address    String
  registeredAt DateTime
  brand      String?
  companyCode String @unique
  ieCode String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt DateTime?

  users UserMapping[]

  orgStructure OrgStructure[]
  userAccesses   UserAccess[]

}

model GroupCompanyMaster {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  code       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt DateTime?


}

model UserActivity {
  id         String   @id @default(uuid()) @db.Uuid
  token      String
  version    String
  userId     String   @unique @db.Uuid
  userAgent  String
  ip         String
  tabId      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  expireAt   DateTime

  @@index([userId])
}

model UserMapping {
  userId     String @db.Uuid
  companyId  String @db.Uuid

  reportingManagerId String @db.Uuid
  status             UserStatus @default(ACTIVE)
  designation        String?  
  employeeId         String?    @unique

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    UserMaster    @relation(fields: [userId], references: [id])
  company CompanyMaster @relation(fields: [companyId], references: [id])
  reportingManager   UserMaster   @relation("ManagerToSubordinate", fields: [reportingManagerId], references: [id])

  roleCode           String     // The foreign key
  role               Role       @relation(fields: [roleCode], references: [roleCode])

  @@id([userId, companyId])
  @@index([companyId])
}

model CompanyMapping {
  companyId        String @db.Uuid
  groupCompanyId   String @db.Uuid
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@id([companyId, groupCompanyId]) // composite primary key
  @@index([groupCompanyId])
}

model OrgStructure {
  id        String   @id @default(uuid()) @db.Uuid
  nodeName  String  
  nodeType  String   
  
  // Ltree configuration
  nodePath  Unsupported("ltree") 
  
  // Relations
  companyId String    @db.Uuid
  company   CompanyMaster @relation(fields: [companyId], references: [id])

  parentId  String?   @db.Uuid
  parent    OrgStructure?  @relation("ParentChild", fields: [parentId], references: [id])
  children  OrgStructure[] @relation("ParentChild")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  nodePermissions UserAccess[]

  // GiST index is essential for ltree performance
  @@index([nodePath], map: "node_path_gist_idx", type: Gist)
}

model Role {
  roleCode        String          @id
  roleName        String
  category        Category
  subCategory     SubCategory
  permissionLevel PermissionLevel
  
  view            Boolean         @default(false)
  modify          Boolean         @default(false)
  approve         Boolean         @default(false)
  initiate        Boolean         @default(false)
  
  isActive        Boolean         @default(true)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userMappings    UserMapping[]
  roleAssignments UserAccess[]

}

model UserAccess {
  id             String   @id @default(uuid()) @db.Uuid
  
  // Foreign Keys
  userId         String   @db.Uuid
  companyId      String   @db.Uuid
  nodeId         String   @db.Uuid
  roleCode       String 
  
  isGlobalAccess Boolean  @default(false)
  accessType     AccessType
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user           UserMaster    @relation(fields: [userId], references: [id])
  company        CompanyMaster @relation(fields: [companyId], references: [id])
  node           OrgStructure  @relation(fields: [nodeId], references: [id])
  role           Role?         @relation(fields: [roleCode], references: [roleCode])
}